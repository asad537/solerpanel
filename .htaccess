RewriteEngine On

# 1. Redirect known folders from the OLD site to the new homepage
RewriteRule ^Boxes-By-Industry/?.*$ https://hafizitsolutions.info/ [R=301,L,NC]
RewriteRule ^boxes-by-industry/?.*$ https://hafizitsolutions.info/ [R=301,L,NC]
RewriteRule ^Boxes-By-Style/?.*$ https://hafizitsolutions.info/ [R=301,L,NC]
RewriteRule ^boxes-by-style/?.*$ https://hafizitsolutions.info/ [R=301,L,NC]
RewriteRule ^Cardboard-Boxes/?.*$ https://hafizitsolutions.info/ [R=301,L,NC]
RewriteRule ^cardboard-boxes/?.*$ https://hafizitsolutions.info/ [R=301,L,NC]
RewriteRule ^Retail-Boxes/?.*$ https://hafizitsolutions.info/ [R=301,L,NC]
RewriteRule ^retail-boxes/?.*$ https://hafizitsolutions.info/ [R=301,L,NC]

# 2. Redirect template extra files
RewriteRule ^index-2\.html$ https://hafizitsolutions.info/ [R=301,L]
RewriteRule ^index-two\.html$ https://hafizitsolutions.info/ [R=301,L]
RewriteRule ^yourwebsitehere\.html$ https://hafizitsolutions.info/ [R=301,L]
RewriteRule ^Blog-details-2\.html$ https://hafizitsolutions.info/ [R=301,L]

# 3. Catch-all: Redirect ANY path that is NOT an actual file or folder on the server
# This will clean up any other hidden old URLs by sending them to the homepage.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . https://hafizitsolutions.info/ [R=301,L]

# 4. Custom 404 (Just in case)
ErrorDocument 404 /error.html
